# ANIMA-bot Environment Variables
# Copy this file to .env and fill in your values

# API Key (required for openai backend)
# For OpenAI: starts with sk-
# For OpenRouter: starts with sk-or-
OPENAI_API_KEY=your-api-key-here

# API Base URL (optional - defaults to OpenAI)
# OpenRouter:   https://openrouter.ai/api/v1
# LM Studio:    http://localhost:1234/v1
# vLLM:         http://localhost:8000/v1
# OPENAI_API_BASE=https://openrouter.ai/api/v1

# Model name (optional - can also be set in config.yaml)
# OpenAI:       gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# OpenRouter:   meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
# OPENAI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Note: For non-OpenAI providers, set context_window in config.yaml
# (default: 8192, adjust based on your model's actual context size)
